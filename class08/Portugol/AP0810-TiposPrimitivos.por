// TiposPrimitivos - Aula 08
// Demonstra os 4 tipos primitivos com exemplos
programa {
    funcao inicio() {
        inteiro valInteiro = 42
        real valReal = 3.14159
        caracter valCaracter = 'A'
        logico valLogico = verdadeiro
        escreva("Inteiro (inteiro): ", valInteiro)
        escreva("Real (real): ", valReal)
        escreva("Caractere (caracter): ", valCaracter)
        escreva("Lógico (logico): ", valLogico)
    }
}
