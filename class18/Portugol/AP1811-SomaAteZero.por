programa {
    funcao inicio() {
        real soma, n
        soma = 0
        escreva("Digite um número (0 para sair): ")
        leia(n)
        enquanto (n != 0) faca
            soma = soma + n
            escreva("Digite um número (0 para sair): ")
            leia(n)
        fimenquanto
        escreva("Soma total: ", soma)
    }
}
